  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "dev:staging": "cross-env VITE_APP_ENV=staging vite --host 0.0.0.0 --port 3001",
    "dev:production": "cross-env VITE_APP_ENV=production vite --host 0.0.0.0 --port 3002",
    "dev:debug": "cross-env DEBUG=true vite --host 0.0.0.0 --port 3000",
    "dev:mock": "concurrently \"npm run dev\" \"npm run mock:server\"",
    "build": "vite build",
    "build:staging": "cross-env VITE_APP_ENV=staging vite build",
    "build:production": "cross-env VITE_APP_ENV=production vite build",
    "build:analyze": "cross-env ANALYZE=true vite build",
    "build:profile": "vite build --mode production && source-map-explorer 'dist/assets/*.js'",
    "build:report": "vite build && npx vite-bundle-visualizer",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "preview:staging": "cross-env VITE_APP_ENV=staging vite preview --port 4174",
    "start": "npm run dev",
    "serve": "npm run preview",
    "clean": "rimraf dist node_modules/.vite .eslintcache",
    "clean:all": "rimraf dist node_modules .eslintcache coverage storybook-static",
    "clean:cache": "rimraf node_modules/.vite node_modules/.cache",
    "reinstall": "npm run clean:all && npm install",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "lint:quiet": "eslint . --ext .js,.jsx,.ts,.tsx --quiet",
    "lint:staged": "lint-staged",
    "lint:css": "stylelint 'src/**/*.{css,scss,less}'",
    "lint:css:fix": "stylelint 'src/**/*.{css,scss,less}' --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,json,md}\"",
    "format:staged": "prettier --write --staged",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "typecheck:watch": "tsc --noEmit --skipLibCheck --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ui": "vitest --coverage --ui",
    "test:coverage:report": "vitest run --coverage --reporter=html",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:e2e:ci": "cypress run --browser chrome --headless",
    "test:e2e:record": "cypress run --record --key $CYPRESS_RECORD_KEY",
    "test:e2e:component": "cypress run --component",
    "test:playwright": "playwright test",
    "test:playwright:ui": "playwright test --ui",
    "test:playwright:headed": "playwright test --headed",
    "test:playwright:debug": "playwright test --debug",
    "test:a11y": "cypress run --spec 'cypress/e2e/accessibility/**'",
    "test:performance": "lighthouse http://localhost:3000 --output=json --output-path=./reports/lighthouse.json",
    "test:visual": "npx percy exec -- cypress run",
    "test:all": "npm-run-all --parallel lint typecheck test test:e2e",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:deploy": "storybook build && npx chromatic --project-token=$CHROMATIC_TOKEN",
    "storybook:test": "test-storybook",
    "mock:server": "node scripts/mock-server.js",
    "generate": "plop",
    "generate:component": "plop component",
    "generate:page": "plop page",
    "generate:hook": "plop hook",
    "generate:service": "plop service",
    "generate:context": "plop context",
    "generate:test": "plop test",
    "docker:build": "docker build -t trackspace-frontend .",
    "docker:run": "docker run -p 3000:80 trackspace-frontend",
    "docker:compose": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "docker:compose:build": "docker-compose build --no-cache",
    "deploy": "npm run build:production && npm run deploy:upload",
    "deploy:staging": "npm run build:staging && npm run deploy:upload:staging",
    "deploy:preview": "npx vercel --yes",
    "deploy:production": "npx vercel --prod --yes",
    "deploy:upload": "node scripts/deploy.js",
    "deploy:upload:staging": "cross-env DEPLOY_ENV=staging node scripts/deploy.js",
    "deploy:cloudflare": "npm run build:production && npx wrangler pages publish dist",
    "deploy:netlify": "npm run build:production && npx netlify deploy --prod --dir=dist",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "release:dry": "standard-version --dry-run",
    "commit": "cz",
    "prepare": "husky install",
    "precommit": "lint-staged",
    "prepush": "npm run test && npm run lint",
    "postinstall": "husky install",
    "audit:deps": "npm audit --production",
    "audit:licenses": "license-checker --summary",
    "audit:security": "snyk test",
    "audit:deps:fix": "npm audit fix",
    "audit:outdated": "npm outdated --long",
    "deps:check": "depcheck",
    "deps:update": "npm-check-updates -u",
    "deps:update:interactive": "npm-check-updates -i",
    "deps:circular": "madge --circular src/",
    "deps:graph": "madge --image dependency-graph.svg src/",
    "analyze:bundle": "source-map-explorer 'dist/assets/*.js'",
    "analyze:webpack": "webpack-bundle-analyzer dist/stats.json",
    "analyze:size": "bundlesize",
    "analyze:deps": "depcheck --ignores 'eslint-*,@types/*,prettier,husky'",
    "i18n:extract": "node scripts/extract-translations.js",
    "i18n:check": "node scripts/check-translations.js",
    "i18n:sync": "node scripts/sync-translations.js",
    "db:seed": "node scripts/seed-mock-data.js",
    "db:reset": "node scripts/reset-mock-data.js",
    "docs:generate": "typedoc --out docs/api src/",
    "docs:serve": "npx serve docs/api",
    "health:check": "node scripts/health-check.js",
    "perf:audit": "lighthouse http://localhost:3000 --view",
    "validate": "npm-run-all --parallel lint typecheck test build"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "not safari < 14",
      "not ios_saf < 14",
      "not and_uc > 0",
      "not kaios > 0"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version",
      "last 1 edge version"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write",
      "vitest related --run"
    ],
    "*.{css,scss,less}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{png,jpeg,jpg,gif,svg}": [
      "imagemin-lint-staged"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "type-enum": [
        2,
        "always",
        [
          "feat",
          "fix",
          "docs",
          "style",
          "refactor",
          "perf",
          "test",
          "build",
          "ci",
          "chore",
          "revert",
          "wip",
          "release",
          "security",
          "deps",
          "config",
          "i18n",
          "a11y",
          "ux"
        ]
      ],
      "type-case": [2, "always", "lower-case"],
      "type-empty": [2, "never"],
      "scope-case": [2, "always", "lower-case"],
      "subject-case": [2, "never", ["sentence-case", "start-case", "pascal-case", "upper-case"]],
      "subject-empty": [2, "never"],
      "subject-full-stop": [2, "never", "."],
      "subject-min-length": [2, "always", 10],
      "subject-max-length": [2, "always", 100],
      "header-max-length": [2, "always", 120],
      "body-leading-blank": [2, "always"],
      "body-max-line-length": [2, "always", 200],
      "footer-leading-blank": [2, "always"],
      "footer-max-line-length": [2, "always", 200]
    }
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog",
      "maxHeaderWidth": 120,
      "maxLineWidth": 200,
      "defaultType": "feat",
      "defaultScope": "",
      "defaultSubject": "",
      "defaultBody": "",
      "defaultIssues": "",
      "types": {
        "feat": {
          "description": "A new feature or enhancement",
          "title": "Features"
        },
        "fix": {
          "description": "A bug fix",
          "title": "Bug Fixes"
        },
        "docs": {
          "description": "Documentation only changes",
          "title": "Documentation"
        },
        "style": {
          "description": "Changes that do not affect the meaning of the code",
          "title": "Styles"
        },
        "refactor": {
          "description": "A code change that neither fixes a bug nor adds a feature",
          "title": "Code Refactoring"
        },
        "perf": {
          "description": "A code change that improves performance",
          "title": "Performance Improvements"
        },
        "test": {
          "description": "Adding missing tests or correcting existing tests",
          "title": "Tests"
        },
        "build": {
          "description": "Changes that affect the build system or external dependencies",
          "title": "Builds"
        },
        "ci": {
          "description": "Changes to CI configuration files and scripts",
          "title": "Continuous Integration"
        },
        "chore": {
          "description": "Other changes that don't modify src or test files",
          "title": "Chores"
        },
        "revert": {
          "description": "Reverts a previous commit",
          "title": "Reverts"
        },
        "security": {
          "description": "Security vulnerability fix or improvement",
          "title": "Security"
        }
      }
    }
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "browser": true,
      "es2024": true,
      "node": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:react/recommended",
      "plugin:react/jsx-runtime",
      "plugin:react-hooks/recommended",
      "plugin:jsx-a11y/recommended",
      "plugin:import/recommended",
      "plugin:testing-library/react",
      "plugin:jest-dom/recommended",
      "plugin:storybook/recommended",
      "prettier"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module",
      "ecmaFeatures": {
        "jsx": true
      }
    },
    "plugins": [
      "react",
      "react-hooks",
      "react-refresh",
      "jsx-a11y",
      "import",
      "unused-imports",
      "simple-import-sort",
      "testing-library",
      "jest-dom",
      "security"
    ],
    "settings": {
      "react": {
        "version": "detect"
      },
      "import/resolver": {
        "node": {
          "extensions": [".js", ".jsx", ".ts", ".tsx"]
        },
        "alias": {
          "map": [
            ["@", "./src"],
            ["@components", "./src/components"],
            ["@pages", "./src/pages"],
            ["@hooks", "./src/hooks"],
            ["@services", "./src/services"],
            ["@utils", "./src/utils"],
            ["@contexts", "./src/contexts"],
            ["@config", "./src/config"],
            ["@styles", "./src/styles"],
            ["@assets", "./src/assets"],
            ["@constants", "./src/constants"],
            ["@types", "./src/types"],
            ["@api", "./src/api"],
            ["@store", "./src/store"],
            ["@layouts", "./src/layouts"],
            ["@features", "./src/features"],
            ["@lib", "./src/lib"]
          ],
          "extensions": [".js", ".jsx", ".ts", ".tsx", ".json"]
        }
      }
    },
    "rules": {
      "react-refresh/only-export-components": ["warn", { "allowConstantExport": true }],
      "react/prop-types": "off",
      "react/react-in-jsx-scope": "off",
      "react/jsx-no-target-blank": ["error", { "enforceDynamicLinks": "always" }],
      "react/jsx-key": ["error", { "checkFragmentShorthand": true }],
      "react/jsx-no-useless-fragment": ["warn", { "allowExpressions": true }],
      "react/jsx-curly-brace-presence": ["warn", { "props": "never", "children": "never" }],
      "react/self-closing-comp": ["warn", { "component": true, "html": true }],
      "react/no-array-index-key": "warn",
      "react/no-danger": "error",
      "react/no-deprecated": "error",
      "react/no-unstable-nested-components": ["error", { "allowAsProps": true }],
      "react/function-component-definition": ["warn", {
        "namedComponents": "function-declaration",
        "unnamedComponents": "arrow-function"
      }],
      "react/jsx-pascal-case": ["error", { "allowAllCaps": true }],
      "react/jsx-boolean-value": ["warn", "never"],
      "react/jsx-fragments": ["warn", "syntax"],
      "react/hook-use-state": "warn",
      "react/jsx-no-constructed-context-values": "error",
      "react/no-object-type-as-default-prop": "warn",
      "react-hooks/rules-of-hooks": "error",
      "react-hooks/exhaustive-deps": "warn",
      "import/no-unresolved": "off",
      "import/no-duplicates": "error",
      "import/no-cycle": ["error", { "maxDepth": 3 }],
      "import/no-self-import": "error",
      "import/no-useless-path-segments": "error",
      "import/first": "error",
      "import/newline-after-import": "error",
      "import/no-named-as-default": "warn",
      "import/no-named-as-default-member": "warn",
      "import/no-anonymous-default-export": "warn",
      "simple-import-sort/imports": ["error", {
        "groups": [
          ["^react", "^@?\\w"],
          ["^@/(components|pages|hooks|services|utils|contexts|config|styles|assets|constants|types|api|store|layouts|features|lib)(/.*|$)"],
          ["^\\.\\.(?!/?$)", "^\\.\\./?$"],
          ["^\\./(?=.*/)(?!/?$)", "^\\.(?!/?$)", "^\\./?$"],
          ["^.+\\.s?css$"]
        ]
      }],
      "simple-import-sort/exports": "error",
      "unused-imports/no-unused-imports": "error",
      "unused-imports/no-unused-vars": ["warn", {
        "vars": "all",
        "varsIgnorePattern": "^_",
        "args": "after-used",
        "argsIgnorePattern": "^_"
      }],
      "jsx-a11y/anchor-is-valid": ["error", {
        "components": ["Link"],
        "specialLink": ["to"],
        "aspects": ["invalidHref", "preferButton"]
      }],
      "jsx-a11y/click-events-have-key-events": "warn",
      "jsx-a11y/no-static-element-interactions": "warn",
      "jsx-a11y/img-redundant-alt": "error",
      "jsx-a11y/label-has-associated-control": ["error", { "assert": "either" }],
      "security/detect-object-injection": "off",
      "security/detect-non-literal-regexp": "warn",
      "security/detect-unsafe-regex": "error",
      "security/detect-buffer-noassert": "error",
      "security/detect-eval-with-expression": "error",
      "security/detect-no-csrf-before-method-override": "error",
      "security/detect-possible-timing-attacks": "warn",
      "no-console": ["warn", { "allow": ["warn", "error", "info"] }],
      "no-debugger": "error",
      "no-alert": "warn",
      "no-var": "error",
      "prefer-const": "error",
      "prefer-template": "warn",
      "prefer-destructuring": ["warn", { "object": true, "array": false }],
      "prefer-arrow-callback": "warn",
      "prefer-rest-params": "error",
      "prefer-spread": "error",
      "no-param-reassign": ["error", { "props": false }],
      "no-shadow": "error",
      "no-unused-expressions": ["error", { "allowShortCircuit": true, "allowTernary": true }],
      "no-return-await": "error",
      "no-await-in-loop": "warn",
      "no-promise-executor-return": "error",
      "require-atomic-updates": "error",
      "no-unmodified-loop-condition": "error",
      "no-constant-binary-expression": "error",
      "no-new-native-nonconstructor": "error",
      "no-duplicate-imports": "off",
      "object-shorthand": ["warn", "always"],
      "arrow-body-style": ["warn", "as-needed"],
      "curly": ["error", "all"],
      "eqeqeq": ["error", "always"],
      "no-eval": "error",
      "no-implied-eval": "error",
      "no-extend-native": "error",
      "no-extra-bind": "error",
      "no-floating-decimal": "error",
      "no-implicit-coercion": ["warn", { "allow": ["!!"] }],
      "no-lone-blocks": "error",
      "no-new-wrappers": "error",
      "no-throw-literal": "error",
      "no-useless-concat": "warn",
      "no-useless-rename": "error",
      "no-useless-return": "warn",
      "radix": "error",
      "spaced-comment": ["warn", "always", { "markers": ["/"] }],
      "max-depth": ["warn", 4],
      "max-nested-callbacks": ["warn", 4],
      "max-params": ["warn", 5],
      "max-lines-per-function": ["warn", { "max": 300, "skipBlankLines": true, "skipComments": true }],
      "max-lines": ["warn", { "max": 500, "skipBlankLines": true, "skipComments": true }],
      "complexity": ["warn", 20],
      "no-restricted-imports": ["error", {
        "paths": [
          {
            "name": "lodash",
            "message": "Import specific lodash functions instead: import debounce from 'lodash/debounce'"
          },
          {
            "name": "moment",
            "message": "Use date-fns or dayjs instead of moment."
          }
        ],
        "patterns": [
          {
            "group": ["../**/.*"],
            "message": "Do not import from relative paths using dot notation beyond the parent."
          }
        ]
      }],
      "no-restricted-globals": [
        "error",
        {
          "name": "event",
          "message": "Use local event parameter instead of the global 'event' object."
        },
        {
          "name": "fdescribe",
          "message": "Do not commit fdescribe. Use describe instead."
        },
        {
          "name": "fit",
          "message": "Do not commit fit. Use it instead."
        }
      ]
    },
    "overrides": [
      {
        "files": ["**/*.test.{js,jsx,ts,tsx}", "**/*.spec.{js,jsx,ts,tsx}"],
        "env": {
          "jest": true
        },
        "rules": {
          "max-lines-per-function": "off",
          "max-nested-callbacks": "off",
          "no-restricted-imports": "off"
        }
      },
      {
        "files": ["**/*.stories.{js,jsx,ts,tsx}"],
        "rules": {
          "import/no-anonymous-default-export": "off",
          "max-lines-per-function": "off"
        }
      },
      {
        "files": ["scripts/**/*.js", "config/**/*.js"],
        "env": {
          "node": true
        },
        "rules": {
          "no-console": "off"
        }
      }
    ]
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 2,
    "useTabs": false,
    "printWidth": 100,
    "bracketSpacing": true,
    "bracketSameLine": false,
    "arrowParens": "always",
    "endOfLine": "lf",
    "quoteProps": "as-needed",
    "jsxSingleQuote": false,
    "htmlWhitespaceSensitivity": "css",
    "embeddedLanguageFormatting": "auto",
    "singleAttributePerLine": false,
    "proseWrap": "preserve",
    "overrides": [
      {
        "files": "*.css",
        "options": {
          "singleQuote": false,
          "tabWidth": 2
        }
      },
      {
        "files": "*.md",
        "options": {
          "proseWrap": "always",
          "tabWidth": 2
        }
      },
      {
        "files": ["*.json", ".prettierrc", ".eslintrc"],
        "options": {
          "tabWidth": 2
        }
      },
      {
        "files": "*.yml",
        "options": {
          "tabWidth": 2,
          "singleQuote": false
        }
      }
    ]
  },
  "stylelint": {
    "extends": [
      "stylelint-config-standard"
    ],
    "plugins": [
      "stylelint-order"
    ],
    "rules": {
      "declaration-block-no-duplicate-properties": true,
      "declaration-block-no-shorthand-property-overrides": true,
      "block-no-empty": true,
      "color-no-invalid-hex": true,
      "font-family-no-duplicate-names": true,
      "function-calc-no-unspaced-operator": true,
      "no-duplicate-selectors": true,
      "no-empty-source": true,
      "no-descending-specificity": null,
      "selector-class-pattern": null,
      "custom-property-pattern": null,
      "value-keyword-case": null,
      "property-no-vendor-prefix": null,
      "declaration-empty-line-before": null,
      "comment-empty-line-before": null,
      "at-rule-no-unknown": [true, {
        "ignoreAtRules": ["tailwind", "apply", "variants", "responsive", "screen", "layer"]
      }],
      "order/properties-alphabetical-order": null,
      "order/properties-order": [
        "content",
        "position",
        "top",
        "right",
        "bottom",
        "left",
        "z-index",
        "display",
        "flex",
        "flex-direction",
        "flex-wrap",
        "flex-flow",
        "flex-grow",
        "flex-shrink",
        "flex-basis",
        "align-items",
        "align-self",
        "align-content",
        "justify-content",
        "justify-items",
        "justify-self",
        "gap",
        "row-gap",
        "column-gap",
        "grid",
        "grid-template",
        "grid-template-columns",
        "grid-template-rows",
        "grid-template-areas",
        "grid-auto-flow",
        "grid-auto-columns",
        "grid-auto-rows",
        "grid-column",
        "grid-row",
        "grid-area",
        "order",
        "float",
        "clear",
        "box-sizing",
        "width",
        "min-width",
        "max-width",
        "height",
        "min-height",
        "max-height",
        "margin",
        "margin-top",
        "margin-right",
        "margin-bottom",
        "margin-left",
        "padding",
        "padding-top",
        "padding-right",
        "padding-bottom",
        "padding-left",
        "overflow",
        "overflow-x",
        "overflow-y",
        "border",
        "border-width",
        "border-style",
        "border-color",
        "border-radius",
        "border-top",
        "border-right",
        "border-bottom",
        "border-left",
        "outline",
        "background",
        "background-color",
        "background-image",
        "background-repeat",
        "background-position",
        "background-size",
        "background-clip",
        "color",
        "font",
        "font-family",
        "font-size",
        "font-weight",
        "font-style",
        "font-variant",
        "line-height",
        "letter-spacing",
        "text-align",
        "text-decoration",
        "text-transform",
        "text-indent",
        "text-overflow",
        "text-shadow",
        "white-space",
        "word-break",
        "word-spacing",
        "word-wrap",
        "vertical-align",
        "list-style",
        "cursor",
        "pointer-events",
        "user-select",
        "visibility",
        "opacity",
        "box-shadow",
        "transform",
        "transition",
        "animation",
        "appearance",
        "will-change"
      ]
    },
    "overrides": [
      {
        "files": ["**/*.scss"],
        "customSyntax": "postcss-scss"
      }
    ]
  },
  "postcss": {
    "plugins": {
      "postcss-import": {},
      "postcss-nested": {},
      "postcss-custom-media": {},
      "postcss-preset-env": {
        "stage": 2,
        "features": {
          "nesting-rules": true,
          "custom-media-queries": true,
          "media-query-ranges": true
        },
        "autoprefixer": {
          "flexbox": "no-2009",
          "grid": "autoplace"
        }
      },
      "cssnano": {
        "preset": ["default", {
          "discardComments": {
            "removeAll": true
          },
          "normalizeWhitespace": true,
          "colormin": true,
          "reduceIdents": false,
          "zindex": false
        }]
      }
    }
  },
  "bundlesize": [
    {
      "path": "dist/assets/*.js",
      "maxSize": "250 kB",
      "compression": "gzip"
    },
    {
      "path": "dist/assets/*.css",
      "maxSize": "50 kB",
      "compression": "gzip"
    },
    {
      "path": "dist/index.html",
      "maxSize": "10 kB"
    }
  ],
  "msw": {
    "workerDirectory": "public"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "18",
        "react-dom": "18"
      },
      "ignoreMissing": [
        "@babel/*",
        "webpack"
      ]
    },
    "overrides": {
      "semver": ">=7.5.4",
      "optionator": ">=0.9.3",
      "tough-cookie": ">=4.1.3"
    }
  },
  "overrides": {
    "semver": ">=7.5.4",
    "optionator": ">=0.9.3",
    "tough-cookie": ">=4.1.3",
    "word-wrap": ">=1.2.5",
    "xml2js": ">=0.5.0",
    "json5": ">=2.2.3",
    "http-cache-semantics": ">=4.1.1"
  },
  "resolutions": {
    "semver": ">=7.5.4",
    "optionator": ">=0.9.3",
    "tough-cookie": ">=4.1.3",
    "json5": ">=2.2.3"
  },
  "volta": {
    "node": "20.10.0",
    "npm": "10.2.5"
  },
  "packageManager": "npm@10.2.5",
  "sideEffects": [
    "*.css",
    "*.scss",
    "*.less"
  ]
}
